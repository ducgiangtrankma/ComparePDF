# Copy to .env and fill in (never commit .env)
OPENAI_API_KEY=sk-your-key-here
# OPENAI_MODEL=gpt-4o-mini

# SharePoint integration
# SHAREPOINT_WEB_URL=https://yourtenant.sharepoint.com/sites/yoursite
# SHAREPOINT_FETCH_MODE=power_automate
# SHAREPOINT_FETCH_URL=https://prod-xx.logic.azure.com/...   # required for power_automate mode
# SHAREPOINT_LIST_URL=https://prod-xx.logic.azure.com/...    # urlGetAllFilesNameSharePoint
# SHAREPOINT_DELETE_URL=https://prod-xx.logic.azure.com/...  # urlDeleteFileSharePoint (optional)
# SHAREPOINT_SIGNATURE_LOCATION=Shared Documents/signatures   # file hoặc folder chữ ký mẫu để so sánh chữ ký tay
# SHAREPOINT_USERNAME=your-user@domain.com                   # required for rest mode
# SHAREPOINT_PASSWORD=your-password                          # required for rest mode

# Audit persistence
# DATABASE_URL=postgresql+psycopg://ai_pdf_compare:Mk3M6KnC5FYexnc2@118.70.239.146:5432/ai_pdf_compare
# Docker Compose (docker-compose.yml) ghi đè DATABASE_URL trỏ host `postgres` — không cần đổi dòng trên khi chạy stack đầy đủ.
# COMPARE_LOG_PATH=logs/compare_audit.log // empty not write to folder logs
# COMPARE_WRITE_DB=0   # skip DB inserts when running uvicorn by hand (optional)
